# ============================================================
# VARIABLES FRONTEND — Copier en .env.local pour le dev
# Toutes les variables VITE_* sont exposées au navigateur
# NE JAMAIS mettre de secrets dans ces variables
# ============================================================

# URL de base de l'API Django
VITE_API_URL=http://localhost/api/v1

# Nom de l'application (affiché dans l'UI)
VITE_APP_NAME=Oeuvres Sociales

# Version
VITE_APP_VERSION=1.0.0

# Environnement
VITE_ENV=development
