# ============================================================
# VARIABLES D'ENVIRONNEMENT — Développement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER LE FICHIER .env
# ============================================================

# ── Django ────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development

# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CHANGEZ-MOI-EN-DEV-UNIQUEMENT-XXXXX

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données ───────────────────────────────────────
DB_NAME=oeuvres_sociales_dev
DB_USER=oeuvres_user
DB_PASSWORD=oeuvres_password_dev
DB_HOST=db          # Nom du service Docker Compose
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────
# Durées en dev (plus longues pour le confort)
JWT_ACCESS_LIFETIME_MINUTES=480
JWT_REFRESH_LIFETIME_DAYS=30

# ── CORS ──────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Email (MailHog en dev) ────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@oeuvres-sociales.dz

# ── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0

# ── Sentry (désactivé en dev) ────────────────────────────
SENTRY_DSN=

# ── PostgreSQL (pour docker-compose) ─────────────────────
POSTGRES_DB=oeuvres_sociales_dev
POSTGRES_USER=oeuvres_user
POSTGRES_PASSWORD=oeuvres_password_dev
