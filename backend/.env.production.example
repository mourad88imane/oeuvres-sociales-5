# ============================================================
# VARIABLES D'ENVIRONNEMENT — Production
# ============================================================
# NE JAMAIS COMMITTER CE FICHIER
# Copier depuis .env.example et remplir les valeurs
# ============================================================

# ── Django ────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=CHANGEZ-MOI-g6s7fd8g7sd6f8g7sd6f8g7sd6f8g7sd
DEBUG=False
ALLOWED_HOSTS=oeuvres-sociales.dz,api.oeuvres-sociales.dz
SITE_URL=https://oeuvres-sociales.dz

# ── Base de données ───────────────────────────────────────
DB_NAME=oeuvres_sociales
DB_USER=oeuvres_user
DB_PASSWORD=CHANGEZ-MOI-password-fort-32-caracteres
DB_HOST=pgbouncer
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://:CHANGEZ-MOI-redis-password@redis:6379/0
REDIS_PASSWORD=CHANGEZ-MOI-redis-password

# ── JWT ───────────────────────────────────────────────────
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_DAYS=7

# ── CORS ──────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://oeuvres-sociales.dz

# ── Email (SMTP production) ───────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.oeuvres-sociales.dz
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@oeuvres-sociales.dz
EMAIL_HOST_PASSWORD=CHANGEZ-MOI
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@oeuvres-sociales.dz

# ── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGEZ-MOI-redis-password@redis:6379/0

# ── Sentry ────────────────────────────────────────────────
SENTRY_DSN=https://public:private@sentry.oeuvres-sociales.dz/1
APP_VERSION=1.0.0

# ── PostgreSQL (pour docker-compose) ─────────────────────
POSTGRES_DB=oeuvres_sociales
POSTGRES_USER=oeuvres_user
POSTGRES_PASSWORD=CHANGEZ-MOI-password-fort-32-caracteres
