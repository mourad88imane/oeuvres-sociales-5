msgid "Paramètre 'code' requis."
msgstr "المعامل 'code' مطلوب."

#: apps/reporting/views.py:367
msgid "Aucune donnée\n"
msgstr "لا توجد بيانات\n"

#: apps/reporting/views.py:392
msgid "Aucune donnée"
